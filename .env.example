# Sports Platform
PLATFORM_URL=https://your-sports-platform.com
PLATFORM_LOGIN_URL=https://your-sports-platform.com/users/sign_in
PLATFORM_EVENTS_URL=https://your-sports-platform.com/events?filter=upcoming&region=your-region
PLATFORM_EMAIL=your_email@example.com
PLATFORM_PASSWORD=your_password_here

# Event Configuration
EVENT_ORGANISER_NAME=Your Sports Club Name
EVENT_LOCATION_WED=Club - Wednesday Venue
EVENT_LOCATION_THU=Club - Thursday Venue

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_TO_NUMBER=+1XXXXXXXXXX

# SendGrid Email
SENDGRID_API_KEY=SG.your-key-here
SENDGRID_FROM_EMAIL=your_verified_sender@email.com
SENDGRID_TO_EMAIL=your_recipient@email.com

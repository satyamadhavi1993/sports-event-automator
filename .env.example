# UBR
UBR_BASE_URL=https://your-ubr-instance-url.com
UBR_EMAIL=your_email_here
UBR_PASSWORD=your_password_here

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Twilio SMS
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_TO_NUMBER=+1XXXXXXXXXX

# SendGrid Email
SENDGRID_API_KEY=SG.your-key-here
SENDGRID_FROM_EMAIL=your_verified_sender@email.com
SENDGRID_TO_EMAIL=your_recipient@email.com

# Redis
REDIS_URL=redis://localhost:6379

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
